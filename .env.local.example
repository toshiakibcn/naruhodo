# いずれか1つを設定してください（複数設定した場合は Anthropic > OpenAI > DeepSeek の優先順）

# Anthropic Claude を使う場合
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# OpenAI を使う場合
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# DeepSeek を使う場合
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# サイト全体にBasic認証をかける場合（本番公開時は設定を強く推奨）
SITE_USERNAME=naruhodo
SITE_PASSWORD=

# 翻訳APIをCloudflare Workerに切り出す場合（未設定ならNext.js内の/api/translateを使う）
# NEXT_PUBLIC_で始まる変数はブラウザに公開されるため、Worker側でWORKER_SECRETも必ず設定すること
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_WORKER_SECRET=
